---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  lang?: string;
  ogLocale?: string;
  alternateLanguages?: { hrefLang: string; href: string }[];
}

const {
  title,
  description,
  canonical = Astro.url.pathname,
  ogImage = "/favicon.svg",
  lang = "en",
  ogLocale = "en_US",
  alternateLanguages = []
} = Astro.props;

const canonicalUrl = new URL(canonical, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#6650a4" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {alternateLanguages.map((item) => (
      <link rel="alternate" hreflang={item.hrefLang} href={new URL(item.href, Astro.site).toString()} />
    ))}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.toString()} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
